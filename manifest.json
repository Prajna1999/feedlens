{
  "manifest_version": 3,
  "name": "FeedLens",
  "version": "0.2.0",
  "description": "Academic-grade feed classifier for Instagram and YouTube.",
  "permissions": ["storage", "activeTab", "unlimitedStorage"],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://www.youtube.com/*"
  ],
  "background": {
    "scripts": ["src/background/background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": [
        "src/shared/constants.js",
        "src/shared/numbers.js",
        "src/shared/fingerprint.js",
        "src/shared/topics.js",
        "src/shared/observer.js",
        "src/platform/instagram/selectors.js",
        "src/platform/instagram/extractor.js",
        "src/platform/instagram/interactions.js",
        "src/content/instagram.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": [
        "src/shared/constants.js",
        "src/shared/numbers.js",
        "src/shared/fingerprint.js",
        "src/shared/topics.js",
        "src/shared/observer.js",
        "src/platform/youtube/selectors.js",
        "src/platform/youtube/extractor.js",
        "src/platform/youtube/interactions.js",
        "src/content/youtube.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": { "48": "icons/icon-48.png", "128": "icons/icon-128.png" }
  },
  "browser_specific_settings": {
    "gecko": { "id": "feedlens@local", "strict_min_version": "115.0" }
  }
}
